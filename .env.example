PORT=
MONGODB_URI=
NODE_ENV=
APP_ENV=
# Set when running the process as a background worker instead of the web API
WORKER_MODE=
# Comma-separated trusted proxy IPs (for correct client IP behind LB/ingress)
TRUSTED_PROXY_IP=

ACCESS_TOKEN_PRIVATE_KEY=
ACCESS_TOKEN_ADMIN_PRIVATE_KEY=

#PAYMENT LINK ENCRYPTION (64 hex chars each) — MUST match the frontend's keys
ENCRYPTION_KEY=
HMAC_KEY=
# Generic app secret (HMAC/signing)
SECRET_KEY=

#FRONTEND / CALLBACK URLS
FRONTEND_URL=
FRONTEND_URL_APPS_2=
FRONTEND_URL_APPS_3=
REDIRECT_URL=
NOTIFY_URL=

MAIL_ADDRESS=
MAIL_PASSWORD=
MAIL_URL=
MAIL_FORM=
MAIL_TOKEN=
HMAC_VERIFICATION_CODE=

#PAYLABS
PAYLABS_API_URL=
PAYLABS_MERCHANT_ID=

#XENDIT
XENDIT_SECRET_KEY=
XENDIT_SECRET_CALLBACK=

#RATE_LIMIT
RATE_LIMIT_MAX=

#API DOCS (Swagger/ReDoc) — disabled in production. On non-prod, set BOTH to
#require HTTP Basic Auth; leave empty to allow open access (local only).
SWAGGER_USER=
SWAGGER_PASS=

#PAYMENT EXPIRY
# Grace period (ms) before an unpaid order is treated as expired
PAYMENT_GRACE_MS=

#DISCORD WEBHOOKS ALERTS
DISCORD_WEBHOOK_URL_ERROR=
DISCORD_WEBHOOK_URL_REVENUE=
DISCORD_WEBHOOK_URL_SECURITY=
DISCORD_WEBHOOK_URL_API_ERROR=
DISCORD_WEBHOOK_URL_REPORT=
DISCORD_WEBHOOK_URL_AUTH=

#CRON / BATCH SETTINGS
ENABLE_CRON=true
# Toggle individual cron batches
CRON_BATCH_EXPIRE=
CRON_BATCH_FALLBACK=
CRON_BATCH_PRECHECK=
# Batch tuning
BATCH_SIZE=
DRY_RUN=
PRECHECK_CONCURRENCY=
PRECHECK_WINDOW_MS=
PRECHECK_CALL_TIMEOUT_MS=
# One-off migration helper (admin role migration)
MIGRATE_FROM_ID=

#ADMIN SEEDER (required by `seedAdmins` — never hardcode credentials)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=